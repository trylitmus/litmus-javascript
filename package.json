{
  "name": "@trylitmus/sdk",
  "version": "0.5.0",
  "files": [
    "dist"
  ],
  "license": "Apache-2.0",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/trylitmus/litmus-javascript.git"
  },
  "homepage": "https://trylitmus.com",
  "bugs": {
    "url": "https://github.com/trylitmus/litmus-javascript/issues"
  },
  "scripts": {
    "build": "tsup",
    "check": "biome check .",
    "format": "biome check --write .",
    "lint": "biome lint .",
    "test": "vitest run",
    "test:browser": "playwright test",
    "test:all": "vitest run && playwright test",
    "generate": "openapi-typescript contract/openapi.yaml -o src/types/api.gen.ts"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.10",
    "@playwright/test": "^1.59.1",
    "jsdom": "^29.0.1",
    "openapi-typescript": "^7.6.1",
    "tsup": "^8.4.0",
    "typescript": "^5.8.0",
    "vitest": "^3.1.0"
  },
  "packageManager": "pnpm@10.30.3"
}
